<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
"http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">

<node xmlns:tp="http://telepathy.freedesktop.org/wiki/DbusSpec#extensions-v0.1">
    <interface name="org.mvgal.MVGAL">
        <tp:docstring>
            MVGAL DBus Interface
            Multi-Vendor GPU Aggregation Layer for Linux
        </tp:docstring>

        <!-- Properties -->
        <property name="Version" type="s" access="read">
            <tp:docstring>
                Get the MVGAL version string
            </tp:docstring>
        </property>

        <property name="Enabled" type="b" access="readwrite">
            <tp:docstring>
                Whether MVGAL is enabled
            </tp:docstring>
        </property>

        <property name="GPUCount" type="i" access="read">
            <tp:docstring>
                Number of detected GPUs
            </tp:docstring>
        </property>

        <property name="DefaultStrategy" type="s" access="readwrite">
            <tp:docstring>
                Default workload distribution strategy
            </tp:docstring>
        </property>

        <property name="MemoryMigrationEnabled" type="b" access="readwrite">
            <tp:docstring>
                Whether cross-GPU memory migration is enabled
            </tp:docstring>
        </property>

        <property name="DMABufEnabled" type="b" access="readwrite">
            <tp:docstring>
                Whether DMA-BUF support is enabled
            </tp:docstring>
        </property>

        <!-- Methods -->
        <method name="GetGPUInfo">
            <tp:docstring>
                Get information about a specific GPU
            </tp:docstring>
            <arg type="i" name="index" direction="in">
                <tp:docstring>GPU index (0-based)</tp:docstring>
            </arg>
            <arg type="a{sv}" name="info" direction="out">
                <tp:docstring>GPU information as a dictionary</tp:docstring>
            </arg>
        </method>

        <method name="ListGPUs">
            <tp:docstring>
                List all detected GPUs
            </tp:docstring>
            <arg type="a(iissib)" name="gpus" direction="out">
                <tp:docstring>
                    Array of GPU info: id, name, vendor, strategy, enabled, memory_used
                </tp:docstring>
            </arg>
        </method>

        <method name="SetGPUEnabled">
            <tp:docstring>
                Enable or disable a GPU
            </tp:docstring>
            <arg type="i" name="index" direction="in">
                <tp:docstring>GPU index</tp:docstring>
            </arg>
            <arg type="b" name="enabled" direction="in">
                <tp:docstring>Whether to enable the GPU</tp:docstring>
            </arg>
            <arg type="b" name="success" direction="out">
                <tp:docstring>Whether the operation succeeded</tp:docstring>
            </arg>
        </method>

        <method name="SetGPUPriority">
            <tp:docstring>
                Set GPU priority
            </tp:docstring>
            <arg type="i" name="index" direction="in">
                <tp:docstring>GPU index</tp:docstring>
            </arg>
            <arg type="i" name="priority" direction="in">
                <tp:docstring>Priority (lower = higher)</tp:docstring>
            </arg>
            <arg type="b" name="success" direction="out">
                <tp:docstring>Whether the operation succeeded</tp:docstring>
            </arg>
        </method>

        <method name="GetStats">
            <tp:docstring>
                Get runtime statistics
            </tp:docstring>
            <arg type="a{sv}" name="stats" direction="out">
                <tp:docstring>
                    Statistics as a dictionary: total_workloads, workloads_per_gpu,
                    load_balance, memory_allocated, memory_used, avg_latency_ms
                </tp:docstring>
            </arg>
        </method>

        <method name="ResetStats">
            <tp:docstring>
                Reset all statistics to zero
            </tp:docstring>
            <arg type="b" name="success" direction="out">
                <tp:docstring>Whether the operation succeeded</tp:docstring>
            </arg>
        </method>

        <method name="ReloadConfig">
            <tp:docstring>
                Reload configuration from file
            </tp:docstring>
            <arg type="b" name="success" direction="out">
                <tp:docstring>Whether the operation succeeded</tp:docstring>
            </arg>
        </method>

        <method name="SetConfigOption">
            <tp:docstring>
                Set a configuration option
            </tp:docstring>
            <arg type="s" name="key" direction="in">
                <tp:docstring>Configuration key</tp:docstring>
            </arg>
            <arg type="s" name="value" direction="in">
                <tp:docstring>Configuration value</tp:docstring>
            </arg>
            <arg type="b" name="success" direction="out">
                <tp:docstring>Whether the operation succeeded</tp:docstring>
            </arg>
        </method>

        <!-- Signals -->
        <signal name="GPUAdded">
            <tp:docstring>
                Emitted when a new GPU is detected
            </tp:docstring>
            <arg type="i" name="index">
                <tp:docstring>GPU index</tp:docstring>
            </arg>
            <arg type="s" name="name">
                <tp:docstring>GPU name</tp:docstring>
            </arg>
            <arg type="s" name="vendor">
                <tp:docstring>Vendor name</tp:docstring>
            </arg>
        </signal>

        <signal name="GPURemoved">
            <tp:docstring>
                Emitted when a GPU is removed
            </tp:docstring>
            <arg type="i" name="index">
                <tp:docstring>GPU index</tp:docstring>
            </arg>
        </signal>

        <signal name="StatsUpdated">
            <tp:docstring>
                Emitted when statistics are updated
            </tp:docstring>
            <arg type="a{sv}" name="stats">
                <tp:docstring>Updated statistics</tp:docstring>
            </arg>
        </signal>

        <signal name="ConfigChanged">
            <tp:docstring>
                Emitted when configuration changes
            </tp:docstring>
            <arg type="s" name="key">
                <tp:docstring>Changed configuration key</tp:docstring>
            </arg>
            <arg type="s" name="value">
                <tp:docstring>New value</tp:docstring>
            </arg>
        </signal>
    </interface>
</node>
